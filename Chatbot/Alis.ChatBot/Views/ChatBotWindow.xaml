<Window x:Class="Alis.ChatBot.Views.ChatBotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Alis.ChatBot.Views"
        xmlns:converters="clr-namespace:Alis.ChatBot.Converters"
        xmlns:models="clr-namespace:Alis.ChatBot.Models"
        Title="K-SHIFT 챗봇"
        Width="480" Height="700"
        MinWidth="400" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Converters -->
        <converters:MessageAlignmentConverter x:Key="AlignConv"/>
        <converters:MessageBackgroundConverter x:Key="BgConv"/>
        <converters:MessageForegroundConverter x:Key="FgConv"/>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>

        <!-- 역방향: true=Collapsed, false=Visible -->
        <converters:BoolToVisibilityConverter x:Key="InvBoolVis" IsInverted="True"/>
        <converters:InverseBoolConverter x:Key="InvBool"/>
    </Window.Resources>

    <Grid>
        <!-- 로그인 패널 (IsLoggedIn=false일 때 표시) -->
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource InvBoolVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <!-- Upper section: Dark navy gradient with branding -->
            <Border Grid.Row="0" Grid.RowSpan="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1B2A4A" Offset="0"/>
                        <GradientStop Color="#2C3E6B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Branding content in upper area -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Logo icon -->
                <Border Width="64" Height="64" CornerRadius="16"
                        Background="#3A5A8C" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="⬢" FontSize="32" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- Title -->
                <TextBlock Text="K-SHIFT Chatbot" Foreground="White"
                           FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <!-- Subtitle -->
                <TextBlock Text="Master Plan Management System"
                           Foreground="#99FFFFFF" FontSize="12"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Lower section: White card with rounded top corners -->
            <Border Grid.Row="1" Background="White" CornerRadius="20,20,0,0">
                <Grid Margin="30,28,30,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ID row -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="txtID" Grid.Column="0" Text="ID" Foreground="#666666"                                   
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1" BorderThickness="2"
                                CornerRadius="12" Background="#FAFAFA">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Gray"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="RoyalBlue"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBox x:Name="IdTextBox"
                                     Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="Black"
                                     Padding="10,8" FontSize="14" Height="40"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0" Background="Transparent"
                                     CaretBrush="Black"
                                     FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"
                                     />
                        </Border>
                    </Grid>

                    <!-- Password row -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Password" Foreground="#666666"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Border Grid.Column="1" BorderThickness="2"
                                CornerRadius="12" Background="#FAFAFA">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Gray"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="RoyalBlue"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <PasswordBox x:Name="PasswordBox"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         Padding="10,8" FontSize="14" Height="40"
                                         VerticalContentAlignment="Center"
                                         BorderThickness="0" Background="Transparent"/>
                        </Border>
                    </Grid>

                    <!-- Login button -->
                    <Border Grid.Row="2" CornerRadius="20" Background="#1B2A4A"
                            Margin="0,16,0,0" Height="45" Cursor="Hand">
                        <Button Content="로그인 →" Command="{Binding LoginCommand}"
                                FontSize="15" FontWeight="Bold"
                                Foreground="White" Background="Transparent"
                                BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Border>

                    <!-- Error text -->
                    <TextBlock Grid.Row="3"
                               Text="{Binding LoginError}"
                               Foreground="#FF4444" FontSize="12"
                               TextWrapping="Wrap" Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               Visibility="{Binding LoginError, Converter={StaticResource BoolVis}}"/>

                    <!-- Copyright footer -->
                    <TextBlock Grid.Row="4"
                               Text="Copyright 2025.12ⓒ SPELIX. All rights reserved."
                               Foreground="#AAAAAA" FontSize="10"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 챗봇 패널 (IsLoggedIn=true일 때 표시) -->
        <DockPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolVis}}">

            <!-- 상단 헤더 바 -->
            <Border DockPanel.Dock="Top" Background="#0F4C81" Padding="12,8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusText}" Value="GPU 연결 끊김">
                                            <Setter Property="Fill" Value="#F44336"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" Foreground="White"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="로그아웃" Command="{Binding LogoutCommand}"
                                Padding="8,4" FontSize="11"
                                Background="Transparent" Foreground="White"
                                BorderBrush="#FFFFFF" BorderThickness="1" Cursor="Hand"/>
                    </StackPanel>
                    <TextBlock Text="K-SHIFT Text2SQL" Foreground="White"
                               FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- 예제 질문 패널 -->
            <Border DockPanel.Dock="Top" Background="#F0F4F8" Padding="10,8"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="예제 질문" FontSize="11" Foreground="#888888"
                               FontWeight="SemiBold" Margin="2,0,0,6"/>
                    <WrapPanel>
                        <Button Content="전체 호선 목록 조회"
                                Command="{Binding SampleQuestionCommand}"
                                CommandParameter="전체 호선 목록을 보여줘"
                                Margin="0,0,6,4" Padding="10,5" FontSize="12"
                                Background="White" Foreground="White"
                                BorderBrush="#CCCCCC" BorderThickness="1" Cursor="Hand"/>
                        <Button Content="호선별 블록 수/중량"
                                Command="{Binding SampleQuestionCommand}"
                                CommandParameter="호선별 블록 수와 중량을 알려줘"
                                Margin="0,0,6,4" Padding="10,5" FontSize="12"
                                Background="White" Foreground="White"
                                BorderBrush="#CCCCCC" BorderThickness="1" Cursor="Hand"/>
                        <Button Content="올해 근무일수"
                                Command="{Binding SampleQuestionCommand}"
                                CommandParameter="올해 근무일수는 몇 일이야?"
                                Margin="0,0,6,4" Padding="10,5" FontSize="12"
                                Background="White" Foreground="White"
                                BorderBrush="#CCCCCC" BorderThickness="1" Cursor="Hand"/>
                        <Button Content="공종별 활동 건수"
                                Command="{Binding SampleQuestionCommand}"
                                CommandParameter="공종별 활동 건수를 보여줘"
                                Margin="0,0,6,4" Padding="10,5" FontSize="12"
                                Background="White" Foreground="White"
                                BorderBrush="#CCCCCC" BorderThickness="1" Cursor="Hand"/>
                        <Button Content="컨테이너선 목록"
                                Command="{Binding SampleQuestionCommand}"
                                CommandParameter="컨테이너선 목록을 보여줘"
                                Margin="0,0,6,4" Padding="10,5" FontSize="12"
                                Background="White" Foreground="White"
                                BorderBrush="#CCCCCC" BorderThickness="1" Cursor="Hand"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- 하단 입력 바 -->
            <Border DockPanel.Dock="Bottom" Background="White" Padding="8"
                    BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="전송"
                            Command="{Binding SendCommand}"
                            Width="60" Height="36" Margin="8,0,0,0"
                            Background="#0F4C81" Foreground="White"
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    <TextBox x:Name="InputTextBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="InputTextBox_KeyDown"
                             Padding="8,6" FontSize="14"
                             VerticalContentAlignment="Center"
                             BorderBrush="#DDDDDD" BorderThickness="1"
                             AcceptsReturn="False">
                        <TextBox.IsEnabled>
                            <Binding Path="IsBusy" Converter="{StaticResource InvBool}"/>
                        </TextBox.IsEnabled>
                    </TextBox>
                </DockPanel>
            </Border>

            <!-- 중앙 메시지 목록 -->
            <ScrollViewer x:Name="MessageScroller" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#F5F5F5">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 메시지 버블 -->
                            <Border Margin="8,4" Padding="12,8" CornerRadius="12"
                                    MaxWidth="380"
                                    HorizontalAlignment="{Binding Role, Converter={StaticResource AlignConv}}"
                                    Background="{Binding Role, Converter={StaticResource BgConv}}">
                                <StackPanel>
                                    <!-- 로딩 표시 -->
                                    <TextBlock Text="생각 중..." FontStyle="Italic"
                                               Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"/>

                                    <!-- 메시지 내용 -->
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                               Foreground="{Binding Role, Converter={StaticResource FgConv}}"
                                               Visibility="{Binding IsLoading, Converter={StaticResource InvBoolVis}}"/>

                                    <!-- SQL 코드블록 (HasSql=true일 때) -->
                                    <Border Background="#1E1E1E" CornerRadius="6" Padding="8" Margin="0,6,0,0"
                                            Visibility="{Binding HasSql, Converter={StaticResource BoolVis}}">
                                        <StackPanel>
                                            <TextBox Text="{Binding EditableSql, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="Consolas" FontSize="12"
                                                     Foreground="#D4D4D4" Background="Transparent"
                                                     BorderThickness="0" AcceptsReturn="True"
                                                     TextWrapping="Wrap" MaxHeight="200"
                                                     VerticalScrollBarVisibility="Auto"
                                                     CaretBrush="#D4D4D4"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Button Content="실행"
                                                        Command="{Binding DataContext.ExecuteSqlCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,2" Margin="0,0,4,0"
                                                        Background="#4CAF50" Foreground="White"
                                                        BorderThickness="0" Cursor="Hand"/>
                                                <Button Content="복사"
                                                        Command="{Binding DataContext.CopySqlCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,2"
                                                        Background="#757575" Foreground="White"
                                                        BorderThickness="0" Cursor="Hand"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- 결과 테이블 미리보기 (HasResult=true일 때) -->
                                    <Border Margin="0,6,0,0"
                                            Visibility="{Binding HasResult, Converter={StaticResource BoolVis}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding RowCount, StringFormat='조회 결과: {0}건'}"
                                                       FontWeight="Bold" Margin="0,0,0,4"/>
                                            <DataGrid ItemsSource="{Binding ResultTable}"
                                                      AutoGenerateColumns="True"
                                                      IsReadOnly="True"
                                                      MaxHeight="250"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="Horizontal"
                                                      FontSize="11"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- 보고서 (HasReport=true일 때) -->
                                    <Border Background="#E8F5E9" CornerRadius="4" Padding="8" Margin="0,6,0,0"
                                            Visibility="{Binding HasReport, Converter={StaticResource BoolVis}}">
                                        <TextBlock Text="{Binding Report}" TextWrapping="Wrap" FontSize="12"/>
                                    </Border>

                                    <!-- 타임스탬프 -->
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                               FontSize="10" Foreground="#999999" Margin="0,4,0,0"
                                               HorizontalAlignment="{Binding Role, Converter={StaticResource AlignConv}}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </DockPanel>
    </Grid>
</Window>
